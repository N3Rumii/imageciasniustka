.browser-overlay
    position: fixed
    top: 0
    left: 0
    width: 100vw
    height: 100vh
    background: #111
    z-index: 9999
    display: flex
    flex-direction: column

.browser-topbar
    display: flex
    align-items: center
    padding: 8px 20px
    background: rgba(0, 0, 0, 0.9)
    color: #ccc
    font-size: 13px
    gap: 12px
    z-index: 2
    flex-shrink: 0

.browser-title
    font-weight: bold
    color: #fff

.browser-counter
    color: #888

.browser-controls
    margin-left: auto
    display: flex
    gap: 6px

.browser-btn
    background: rgba(255, 255, 255, 0.08)
    border: 1px solid rgba(255, 255, 255, 0.15)
    color: #aaa
    padding: 4px 12px
    cursor: pointer
    font-size: 13px
    border-radius: 3px
    &:hover
        background: rgba(255, 255, 255, 0.2)
        color: #fff
    &.active
        background: rgba(100, 180, 255, 0.35)
        border-color: rgba(100, 180, 255, 0.5)
        color: #fff

.browser-images
    flex: 1
    overflow-y: auto
    overflow-x: hidden
    display: flex
    flex-direction: column
    align-items: center
    padding: 10px 0
    gap: 4px

.browser-image-wrap
    position: relative
    max-width: 95vw
    .browser-image
        display: block
        max-width: 95vw
        max-height: 95vh
        object-fit: contain
        min-height: 100px
    .browser-image-id
        position: absolute
        bottom: 4px
        right: 6px
        background: rgba(0, 0, 0, 0.7)
        color: #666
        font-size: 10px
        padding: 1px 5px
        border-radius: 2px

.browser-loading
    color: #555
    font-size: 16px
    padding: 60px
    text-align: center

.browser-bottombar
    display: flex
    justify-content: center
    padding: 6px 20px
    background: rgba(0, 0, 0, 0.9)
    color: #444
    font-size: 11px
    z-index: 2
    flex-shrink: 0
